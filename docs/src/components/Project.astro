---
interface Props {
  git: string;
  pypi: string;
  organization?: boolean;
  fullName?: string;
}

const { git, pypi, organization, fullName } = Astro.props;

const urlParts = git.replace('https://github.com/', '').split('/');
const owner = urlParts[0];
const repo = urlParts[1];

const pp = `https://github.com/${owner}.png?size=100`;

---

<div class="project-card">
    <img 
        src={pp} 
        alt={`${owner}'s avatar`}
        class={`owner-avatar ${organization ? 'organization' : 'user'}`}
    />
    <div class="project-info">
        <h3>{repo}</h3>
        <p class="owner">by {fullName || owner}</p>
    </div>
    <div class="project-links">
        <a 
            href={git} 
            target="_blank" 
            rel="noopener noreferrer"
            class="link-github"
        >
            View on GitHub
        </a>
        <a 
            href={`https://pypi.org/project/${pypi}/`}
            target="_blank" 
            rel="noopener noreferrer"
            class="link-pypi"
        >
            View on PyPI
        </a>
    </div>
</div>

<style>
    .project-card {
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        padding: 1.5rem;
        margin: 0 0;
        background: var(--sl-color-gray-6);

        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .owner-avatar {
        width: 48px;
        height: 48px;
        object-fit: cover;
    }

    .owner-avatar.user {
        border-radius: 50%;
    }

    .owner-avatar.organization {
        border-radius: 0.375rem;
    }

    .project-info {
        flex: 1;
        margin: 0;
        padding: 0;
    }

    .project-info h3 {
        margin: 0;
        font-size: 1.25rem;
    }

    .owner {
        margin: -0.25rem 0 0 0;
        color: var(--sl-color-gray-2);
        font-size: 0.9rem;
    }

    .project-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center; /* Add this to vertically center the buttons within the wrapper */
    }

    .project-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
        margin: 0;
    }

    .project-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
    }

    .link-github {
        background: var(--sl-color-gray-6);
        color: var(--sl-color-gray-2);
    }

    .link-github:hover {
        background: var(--sl-color-gray-7);
    }

    .link-pypi {
        background: #0073b7;
        color: white;
    }

    .link-pypi:hover {
        background: rgb(0, 84, 136)
    }
</style>
